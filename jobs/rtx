#!/bin/bash
#SBATCH --job-name=package_name.rtx
#SBATCH --gres=gpu:1
#SBATCH -p RTX
#SBATCH --time=168:00:00
#SBATCH --cpus-per-task=4
#SBATCH -o logs/%j/output.log
#SBATCH --mail-type=ALL
#SBATCH --mail-user=telegram:YOUR_TELEGRAM_ID
#SBATCH --mem=20G


source .venv/bin/activate

mkdir -p logs/${SLURM_JOB_ID}/code
find src/package_name \( -name '*.py' -o -name '*.yaml' \) -exec cp --parents --parents {} logs/${SLURM_JOB_ID}/code/ \;

python -B -m package_name hydra.run.dir=logs/${SLURM_JOB_ID}/hydra
